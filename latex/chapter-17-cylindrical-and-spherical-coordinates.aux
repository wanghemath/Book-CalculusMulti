\@writefile{lof}{\contentsline {figure}{\numberline {17.2}{\ignorespaces Basic cylindrical coordinate surfaces: a cylinder $r=2$, a cone $z=r$, and a horizontal plane $z=2.5$.\relax }}{3}{figure.caption.2}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {17.4}The cylindrical volume element}{3}{section.17.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {17.3}{\ignorespaces The polar base of a cylindrical volume element. Multiplying the base dimensions $dr$ and $r\,d\theta $ by height $dz$ gives $dV=r\,dz\,dr\,d\theta $.\relax }}{4}{figure.caption.3}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {17.5}Worked examples in cylindrical coordinates}{4}{section.17.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {17.4}{\ignorespaces A cross-section of the solid above $z=r$ and below $z=1$. Cylindrical coordinates turn the solid into $0\le r\le 1$, $r\le z\le 1$.\relax }}{5}{figure.caption.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {17.5}{\ignorespaces A solid inside the cylinder $r=1$, above $z=1-r^2$, and below $z=3$.\relax }}{5}{figure.caption.5}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {17.6}Spherical coordinates}{6}{section.17.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {17.6}{\ignorespaces In a vertical cross-section through the $z$-axis, spherical coordinates reduce to right-triangle geometry: $r=\rho \qopname  \relax o{sin}\phi $ and $z=\rho \qopname  \relax o{cos}\phi $.\relax }}{7}{figure.caption.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {17.7}{\ignorespaces Basic spherical coordinate surfaces: the sphere $\rho =2$ and the cone $\phi =\pi /4$.\relax }}{7}{figure.caption.7}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {17.7}The spherical volume element}{8}{section.17.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {17.8}{\ignorespaces The spherical volume factor is a product of three local lengths: $d\rho $, $\rho \,d\phi $, and $\rho \qopname  \relax o{sin}\phi \,d\theta $.\relax }}{8}{figure.caption.8}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {17.8}Worked examples in spherical coordinates}{8}{section.17.8}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {17.9}{\ignorespaces The region inside a sphere and above a cone becomes a simple rectangular box in $(\rho ,\phi ,\theta )$-space.\relax }}{9}{figure.caption.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {17.10}{\ignorespaces A cross-section of the first-octant spherical shell. The full three-dimensional region has $0\le \theta \le \pi /2$ and $0\le \phi \le \pi /2$.\relax }}{10}{figure.caption.10}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {17.9}Choosing among rectangular, cylindrical, and spherical coordinates}{10}{section.17.9}\protected@file@percent }
