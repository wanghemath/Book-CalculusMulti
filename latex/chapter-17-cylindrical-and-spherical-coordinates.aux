\@writefile{lof}{\contentsline {figure}{\numberline {17.1}{\ignorespaces Coordinate systems as languages for geometry. The best language is usually the one whose coordinate surfaces match the boundary surfaces.\relax }}{1}{figure.caption.1}\protected@file@percent }
