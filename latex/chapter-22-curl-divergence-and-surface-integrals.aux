\newlabel{ex:rotfield}{{2.1}{2}{A rotating field}{tcb@cnt@examplebox.2.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces The field $F=\langle -y,x\rangle $ rotates counterclockwise. Its curl points in the positive $z$-direction.\relax }}{3}{figure.caption.1}\protected@file@percent }
\newlabel{ex:curl3d}{{2.2}{3}{Curl of a three-dimensional field}{tcb@cnt@examplebox.2.2}{}}
