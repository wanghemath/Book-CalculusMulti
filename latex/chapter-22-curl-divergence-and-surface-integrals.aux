\newlabel{ex:divexamples}{{3.1}{4}{A source field and an incompressible rotational field}{tcb@cnt@examplebox.3.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces A radial source field has positive divergence. A rotational field can have zero divergence but nonzero curl.\relax }}{4}{figure.caption.2}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {4}Two fundamental identities}{4}{section.4}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {5}Numerical curl and divergence on a grid}{4}{section.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Finite differences approximate divergence and scalar curl from neighboring values on a grid.\relax }}{5}{figure.caption.3}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {6}Surfaces and parameterizations}{5}{section.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces For a parameterized surface, $r_u\times r_v$ gives a normal direction and the local area scale.\relax }}{5}{figure.caption.4}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {7}Surface area}{6}{section.7}\protected@file@percent }
\newlabel{ex:planepatch}{{7.1}{6}{Area of a plane patch}{tcb@cnt@examplebox.7.1}{}}
\@writefile{toc}{\contentsline {section}{\numberline {8}Scalar surface integrals}{6}{section.8}\protected@file@percent }
