\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces For $h(x,y)=\frac  {x^2y}{x^2+y^2}$, the maximum absolute value on circles of radius $r$ decreases linearly toward zero.\relax }}{7}{figure.caption.6}\protected@file@percent }
