\newlabel{ex:directsub}{{3.1}{3}{Direct substitution}{tcb@cnt@workedexample.3.1}{}}
\newlabel{ex:rationalregular}{{3.2}{4}{A rational function at a regular point}{tcb@cnt@workedexample.3.2}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4}Path tests for nonexistence}{4}{section.4}\protected@file@percent }
\newlabel{ex:pathdep}{{4.1}{4}{A classic path-dependent limit}{tcb@cnt@workedexample.4.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Different straight-line paths give different limiting values for $f(x,y)=\frac  {x^2-y^2}{x^2+y^2}$.\relax }}{5}{figure.caption.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Near the origin, the surface approaches different heights from different directions.\relax }}{5}{figure.caption.4}\protected@file@percent }
