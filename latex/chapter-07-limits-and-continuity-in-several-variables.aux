\newlabel{ex:linesnotenough}{{5.1}{5}{Lines are misleading}{tcb@cnt@workedexample.5.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Line paths can all approach zero while a curved path approaches a different value.\relax }}{6}{figure.caption.5}\protected@file@percent }
