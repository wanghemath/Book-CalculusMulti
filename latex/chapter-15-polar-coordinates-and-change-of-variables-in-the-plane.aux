\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Samples from a radial distribution. Polar coordinates separate radius and angle, which is useful for simulation and probability calculations.\relax }}{12}{figure.caption.11}\protected@file@percent }
