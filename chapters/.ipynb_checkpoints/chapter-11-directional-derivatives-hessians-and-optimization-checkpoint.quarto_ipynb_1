        "#| label: fig-ch11-finite-difference-gradient\n",
        "#| fig-cap: Finite differences approximate the gradient when symbolic derivatives are unavailable.\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "def f_vec(p):\n",
        "    x, y = p\n",
        "    return np.exp(0.2*x*y) + x**2 + 0.5*y**2\n",
        "\n",
        "def analytic_grad(p):\n",
        "    x, y = p\n",
        "    return np.array([\n",
        "        0.2*y*np.exp(0.2*x*y) + 2*x,\n",
        "        0.2*x*np.exp(0.2*x*y) + y\n",
        "    ])\n",
        "\n",
        "def finite_grad(f, p, h=1e-4):\n",
        "    p = np.array(p, dtype=float)\n",
        "    g = np.zeros_like(p)\n",
        "    for j in range(len(p)):\n",
        "        e = np.zeros_like(p)\n",
        "        e[j] = 1.0\n",
        "        g[j] = (f(p + h*e) - f(p - h*e)) / (2*h)\n",
        "    return g\n",
        "\n",
        "p = np.array([1.0, -0.5])\n",
        "g_exact = analytic_grad(p)\n",
        "g_fd = finite_grad(f_vec, p)\n",
        "\n",
        "fig, ax = plt.subplots()\n",
        "ax.bar(['exact x', 'exact y', 'finite x', 'finite y'], [g_exact[0], g_exact[1], g_fd[0], g_fd[1]])\n",
        "ax.set_title('Analytic gradient versus finite-difference gradient')\n",
        "ax.grid(True, axis='y', alpha=0.25)\n",
        "plt.show()\n",
        "\n",
        "print('analytic gradient:', g_exact)\n",
        "print('finite-difference gradient:', g_fd)\n",
        "print('difference:', g_fd - g_exact)"
