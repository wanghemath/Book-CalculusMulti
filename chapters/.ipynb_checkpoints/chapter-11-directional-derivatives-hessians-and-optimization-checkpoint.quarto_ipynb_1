        "#| label: fig-ch11-newton-rosenbrock\n",
        "#| fig-cap: Newton-type steps use curvature information and can move differently from gradient descent.\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Rosenbrock function: a standard nonconvex optimization test problem.\n",
        "def rosen(p):\n",
        "    x, y = p\n",
        "    return (1-x)**2 + 20*(y-x**2)**2\n",
        "\n",
        "def grad_rosen(p):\n",
        "    x, y = p\n",
        "    return np.array([\n",
        "        -2*(1-x) - 80*x*(y-x**2),\n",
        "        40*(y-x**2)\n",
        "    ])\n",
        "\n",
        "def hess_rosen(p):\n",
        "    x, y = p\n",
        "    return np.array([\n",
        "        [2 - 80*y + 240*x**2, -80*x],\n",
        "        [-80*x, 40]\n",
        "    ])\n",
        "\n",
        "# Damped Newton iteration.\n",
        "p = np.array([-1.2, 1.2])\n",
        "path = [p.copy()]\n",
        "for _ in range(12):\n",
        "    H = hess_rosen(p)\n",
        "    g = grad_rosen(p)\n",
        "    step = np.linalg.solve(H, -g)\n",
        "    alpha = 1.0\n",
        "    # Simple backtracking for stability.\n",
        "    while rosen(p + alpha*step) > rosen(p) and alpha > 1e-3:\n",
        "        alpha *= 0.5\n",
        "    p = p + alpha*step\n",
        "    path.append(p.copy())\n",
        "path = np.array(path)\n",
