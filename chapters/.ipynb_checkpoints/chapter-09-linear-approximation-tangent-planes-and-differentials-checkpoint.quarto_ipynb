      "source": [
        "#| label: fig-ch09-error-propagation-cylinder\n",
        "#| fig-cap: Linear error propagation predicts how measurement errors in radius and height affect cylinder volume.\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "r0, h0 = 3.0, 10.0\n",
        "r = np.linspace(2.9, 3.1, 160)\n",
        "h = np.linspace(9.8, 10.2, 160)\n",
        "R, H = np.meshgrid(r, h)\n",
        "V = np.pi*R**2*H\n",
        "V0 = np.pi*r0**2*h0\n",
        "L = V0 + 2*np.pi*r0*h0*(R - r0) + np.pi*r0**2*(H - h0)\n",
        "E = V - L\n",
        "\n",
        "fig, ax = plt.subplots()\n",
        "cs = ax.contourf(R, H, E, levels=20)\n",
        "fig.colorbar(cs, ax=ax, label='exact minus linear')\n",
        "ax.scatter([r0], [h0], s=60)\n",
        "ax.set_xlabel('radius $r$')\n",
        "ax.set_ylabel('height $h$')\n",
        "ax.set_title('Linear approximation error for cylinder volume')\n",
        "plt.show()"
      ],
      "id": "fig-ch09-error-propagation-cylinder",
      "execution_count": null,
      "outputs": []
