        "#| label: fig-ch14-average-on-triangle\n",
        "#| fig-cap: Heatmap of f(x,y)=x+2y over the triangular region 0 <= x <= 1, 0 <= y <= 1 - x.\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "x = np.linspace(0, 1, 300)\n",
        "y = np.linspace(0, 1, 300)\n",
        "X, Y = np.meshgrid(x, y)\n",
        "Z = X + 2*Y\n",
        "mask = Y <= 1 - X\n",
        "Z_masked = np.where(mask, Z, np.nan)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(6.5, 5))\n",
        "img = ax.imshow(Z_masked, extent=[0,1,0,1], origin='lower', aspect='equal')\n",
        "ax.plot([0,1], [1,0], color='black')\n",
        "ax.plot([0,1], [0,0], color='black')\n",
        "ax.plot([0,0], [0,1], color='black')\n",
        "fig.colorbar(img, ax=ax, label='$f(x,y)$')\n",
        "ax.set_xlabel('$x$')\n",
        "ax.set_ylabel('$y$')\n",
        "ax.set_title('Average value over a triangular region')\n",
        "plt.show()"
