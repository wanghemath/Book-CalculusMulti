        "#| fig-cap: Area between the line x = y + 1 and the parabola x = (y^2 - 6)/2.\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "y = np.linspace(-2, 4, 400)\n",
        "x_left = (y**2 - 6)/2\n",
