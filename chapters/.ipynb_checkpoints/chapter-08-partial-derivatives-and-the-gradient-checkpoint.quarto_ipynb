      "source": [
        "#| label: fig-ch08-gradient-level-curves\n",
        "#| fig-cap: Gradient vectors are perpendicular to level curves of $H(x,y)=4-x^2/4-y^2$.\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "x = np.linspace(-4, 4, 250)\n",
        "y = np.linspace(-2.3, 2.3, 250)\n",
        "X, Y = np.meshgrid(x, y)\n",
        "H = 4 - X**2/4 - Y**2\n",
        "\n",
        "fig, ax = plt.subplots()\n",
        "cs = ax.contour(X, Y, H, levels=[0, 1, 2, 3, 3.5], linewidths=1.2)\n",
        "ax.clabel(cs, inline=True, fontsize=8)\n",
        "\n",
        "points = np.array([[2, 0], [-2, 0], [0, 1], [0, -1], [1, np.sqrt(3)/2], [-1, -np.sqrt(3)/2]])\n",
        "U = -points[:, 0] / 2\n",
        "V = -2 * points[:, 1]\n",
        "ax.quiver(points[:, 0], points[:, 1], U, V, angles='xy', scale_units='xy', scale=3)\n",
        "ax.scatter(points[:, 0], points[:, 1], s=25)\n",
        "\n",
        "ax.set_aspect('equal', adjustable='box')\n",
        "ax.set_xlabel('x')\n",
        "ax.set_ylabel('y')\n",
        "ax.set_title('Level curves and gradient vectors')\n",
        "ax.grid(True, alpha=0.25)\n",
        "plt.show()"
      ],
